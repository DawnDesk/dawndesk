{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DawnDesk",
  "version": "0.1.3",
  "identifier": "com.dawndesk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Dawndesk",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3NEY0QjBBMTdDOUIzRUYKUldUdnM4a1hDa3RQNTRHUXptTEduRHJVTHdlOUxRMXNUTXZzVklhVm9VSjVybEZVb0FMalBHQVIK",
      "endpoints": [
        "https://github.com/DawnDesk/dawndesk/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/dawndesk-installer.nsh",
        "installMode": "both"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
