{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "deep-link:allow-get-current",
    "deep-link:allow-register",
    "opener:allow-default-urls",
    "opener:allow-open-url",
    "process:allow-restart",
    "updater:default"
  ]
}
